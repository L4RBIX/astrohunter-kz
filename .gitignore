# Environment
.venv/
venv/
env/
.env

# Python cache
__pycache__/
*.py[cod]
*.pyc
*$py.class

# Jupyter
.ipynb_checkpoints/

# Data
# Keep raw archive products and large downloaded light curves out of Git.
data/raw/
data/lightcurves/
data/**/*.fits
data/**/*.fits.gz
data/**/*.lc
data/**/*.lc.gz
!data/README.md
!data/.gitkeep

# Archive/cache products
cache/
.lightkurve-cache/
mastDownload/

# Temporary logs
*.log
logs/

# Results
# Small Phase 1 example figures/tables are allowed when useful for portfolio.
# Avoid committing bulky ad-hoc batches or temporary result files.
results/**/*.tmp
results/**/*.log
